# ──────────────────────────────────────────────────────────────────
#  PennyWise — .gitignore
#  Covers: Node/Vite, Python/FastAPI, Rust/Tauri, Editors, OS files
# ──────────────────────────────────────────────────────────────────

# ─── Secrets & Environment ────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ─── Node / Vite / React ─────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# ─── Logs ────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Python / FastAPI ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
.eggs/

# Sample / test bank statements — never commit real financial data
backend/statement.pdf
backend/statements/
*.pdf

# ─── Rust / Tauri ────────────────────────────────────────────────
src-tauri/target/
src-tauri/gen/android/
src-tauri/gen/apple/

# ─── Editors ─────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace

# ─── Operating System ────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Backup / Temp files ─────────────────────────────────────────
*_backup.*
*.tmp
*.bak
